  alias getInvoiceItems
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return {
    total number required
    data array table.InvoiceItem required
  } required
}

api post /invoices/:id/items {
  alias createInvoiceItem
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    id_product_type number required
    quantity number required
    unit_price number required
    subtotal number required
  }
  return table.InvoiceItem required
}

api put /invoice-items/:id {
  alias updateInvoiceItem
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    id_product_type number
    quantity number
    unit_price number
