  alias getInvoiceById
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return table.Invoice required
}

api post /invoices {
  alias createInvoice
  headers {
    authorization string required
  }
  body {
    id_factory number required
    id_customer number required
    invoice_number string required
    invoice_date string required
    due_date string required
    subtotal number
    tax number
    discount number
    total number
    status string
    notes string
  }
  return table.Invoice required
}

api put /invoices/:id {
  alias updateInvoice
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    id_customer number
    invoice_number string
    invoice_date string
    due_date string
    subtotal number
    tax number
    discount number
    total number
    status string
    notes string
  }
  return table.Invoice required
}

api delete /invoices/:id {
  alias deleteInvoice
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return schema.MessageResponse required
}

