api get /customers {
  alias getCustomers
  headers {
    authorization string required
  }
  query {
    limit number
    offset number
    search string
    is_active boolean
  }
  return {
    total number required
    data array table.Customer required
  } required
}

api get /customers/:id {
  alias getCustomerById
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return table.Customer required
}

api post /customers {
  alias createCustomer
  headers {
    authorization string required
  }
  body {
    code string required
    name string required
    contact_person string
    phone string
    email string
    address string
  }
  return table.Customer required
}

api put /customers/:id {
  alias updateCustomer
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    code string
    name string
    contact_person string
    phone string
    email string
    address string
    is_active boolean
  }
  return table.Customer required
}

api delete /customers/:id {
  alias deleteCustomer
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return schema.MessageResponse required
}

api get /invoices {
  alias getInvoices
  headers {
    authorization string required
  }
  query {
    limit number
    offset number
    id_factory number
    id_customer number
    status string
    start_date string
    end_date string
  }
  return {
    total number required
    data array table.Invoice required
  } required
}

