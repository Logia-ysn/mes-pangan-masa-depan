    total number required
    data array table.Worksheet required
  } required
}

api get /worksheets/:id {
  alias getWorksheetById
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return table.Worksheet required
}

api post /worksheets {
  alias createWorksheet
  headers {
    authorization string required
  }
  body {
    id_factory number required
    worksheet_date string required
    shift string required
    gabah_input number required
    beras_output number required
    menir_output number
    dedak_output number
    sekam_output number
    machine_hours number
    downtime_hours number
    downtime_reason string
    notes string
  }
  return table.Worksheet required
}

api put /worksheets/:id {
  alias updateWorksheet
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    worksheet_date string
    shift string
    gabah_input number
    beras_output number
    menir_output number
    dedak_output number
    sekam_output number
    machine_hours number
    downtime_hours number
    downtime_reason string
    notes string
  }
  return table.Worksheet required
}

api delete /worksheets/:id {
  alias deleteWorksheet
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return schema.MessageResponse required
}

