api get /product-types {
  alias getProductTypes
  headers {
    authorization string required
  }
  query {
    limit number
    offset number
    search string
  }
  return {
    total number required
    data array table.ProductType required
  } required
}

api get /product-types/:id {
  alias getProductTypeById
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return table.ProductType required
}

api post /product-types {
  alias createProductType
  headers {
    authorization string required
  }
  body {
    code string required
    name string required
    description string
    unit string
  }
  return table.ProductType required
}

api put /product-types/:id {
  alias updateProductType
  headers {
    authorization string required
  }
  path {
    id number required
  }
  body {
    code string
    name string
    description string
    unit string
  }
  return table.ProductType required
}

api delete /product-types/:id {
  alias deleteProductType
  headers {
    authorization string required
  }
  path {
    id number required
  }
  return schema.MessageResponse required
}

api get /worksheets {
  alias getWorksheets
  headers {
    authorization string required
  }
  query {
    limit number
    offset number
    id_factory number
    start_date string
