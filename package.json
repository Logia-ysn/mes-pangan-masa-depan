{
  "name": "erp-pangan-masa-depan",
  "version": "1.2.0",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typeorm": "typeorm-ts-node-commonjs",
    "generate-migration": "npm run typeorm migration:generate -- $1 -d ./data-source.ts",
    "migrate": "npm run typeorm migration:run -- -d ./data-source.ts",
    "migrate:prod": "node -r dotenv/config ./node_modules/typeorm/cli.js migration:run -d ./dist/data-source.js",
    "codegen": "codegen-nodejs-typeorm -d design -o types",
    "codegen-init": "npx ts-node ./generate-initial-api.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist",
    "dev": "npm run build && npm start",
    "seed-admin": "npx ts-node ./seed-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@naiv/codegen-nodejs-typeorm": "^0.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.27"
  }
}