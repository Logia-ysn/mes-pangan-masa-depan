# ============================================================
# .dockerignore for All-in-One build
# ============================================================
# NOTE: frontend/ and ml-service/ are NOT excluded here
# because they are built inside the same image.

.env
.env.*
!.env.example
.git
.gitignore
.claude
.vscode

# Node modules (akan di-install ulang di container)
node_modules
frontend/node_modules
ml-service/__pycache__

# Build artifacts
dist
frontend/dist

# Logs
*.log

# Documentation & Design (tidak diperlukan di container)
docs
design

# Backups
backups

# Misc
*.md
!README.md
stitch_executive_dashboard
