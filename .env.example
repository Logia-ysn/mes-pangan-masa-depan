# ============================================================
# MES Pangan Masa Depan — Environment Variables
# ============================================================

# ==========================================
# 🏠 MODE 1: LOCAL DEVELOPMENT (npm run dev)
# ==========================================
# Jalankan DB & ML di Docker: npm run docker:services
# Lalu jalankan backend: npm run dev
# Lalu jalankan frontend: cd frontend && npm run dev

PORT=3000
DATABASE_URL="postgresql://postgres:postgres123@localhost:5434/mes_pangan?schema=public"
ML_SERVICE_URL=http://localhost:8000
NODE_ENV=development

# ==========================================
# 🐳 MODE 2: DOCKER COMPOSE (Multi-container)
# ==========================================
# Jalankan: docker compose up -d --build
# Akses: http://localhost:3010

DB_PASSWORD=postgres123
DB_NAME=mes_pangan

# ==========================================
# 📦 MODE 3: DOCKER ALL-IN-ONE (Single container)
# ==========================================
# Build:
#   docker build -f Dockerfile.allinone -t mes-pangan .
#
# Run:
#   docker run -d --name mes-pangan \
#     -p 80:80 \
#     -v mes-data:/var/lib/postgresql/16/main \
#     -v mes-uploads:/app/uploads \
#     -v mes-backups:/app/backups \
#     -e JWT_SECRET=your-secret-key-here \
#     -e DB_USER=mes_user \
#     -e DB_PASSWORD=mes_password \
#     -e DB_NAME=mes_pangan \
#     mes-pangan
#
# Management:
#   docker logs mes-pangan              # View logs
#   docker exec -it mes-pangan bash     # Shell access
#   docker stop mes-pangan              # Stop
#   docker start mes-pangan             # Start again
#   docker restart mes-pangan           # Restart

# ==========================================
# 🔑 SHARED SETTINGS (All modes)
# ==========================================

# JWT Secret — WAJIB diganti untuk production!
# Generate: openssl rand -base64 64
JWT_SECRET=super-secret-production-key-change-it

# Seed Secret (For initial admin data)
SEED_SECRET=P4ng4nM4s4D3p4nJ4y4!

# Frontend URL (For CORS — digunakan di multi-container mode)
FRONTEND_URL=http://localhost:3010

# All-in-One DB Credentials (hanya untuk Mode 3)
DB_USER=mes_user
# DB_PASSWORD sudah didefinisikan di atas
