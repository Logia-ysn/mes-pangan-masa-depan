# ==========================================
# 🏠 LOCAL DEVELOPMENT SETUP (using NPM)
# ==========================================
# Use "localhost" for HOST when running npm run dev locally.

# Server Port (Backend)
PORT=3000

# Database Configuration (Lokal)
# Jika DB jalan di Docker (port 5434), gunakan localhost:5434
DATABASE_URL="postgresql://postgres:postgres123@localhost:5434/erp_pangan_masa_depan?schema=public"

# ML Service URL (Lokal)
ML_SERVICE_URL=http://localhost:8000

# ==========================================
# 🐳 DOCKER / PRODUCTION SETUP
# ==========================================
# Variables below are used INSIDE docker-compose.yml.
# When running full Docker, services use container names as hosts.

# DB_PASSWORD used by both DB and API containers
DB_PASSWORD=postgres123
DB_NAME=erp_pangan_masa_depan

# JWT Secret (REQUIRED)
# Generate: openssl rand -base64 64
JWT_SECRET=super-secret-production-key-change-it

# Seed Secret (For initial data)
SEED_SECRET=P4ng4nM4s4D3p4nJ4y4!

# Frontend URL (For CORS)
FRONTEND_URL=http://localhost:3010

NODE_ENV=development
