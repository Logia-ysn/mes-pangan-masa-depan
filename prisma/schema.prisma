  Factory   Factory    @relation(fields: [id_factory], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Machine   Machine    @relation(fields: [id_machine], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User      User       @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Worksheet Worksheet? @relation(fields: [id_worksheet], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([id_factory])
  @@index([id_machine])
  @@index([recorded_at])
  @@index([batch_code])
}

enum ShiftHandover_status_enum {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
}

model ShiftHandover {
  id               Int                       @id @default(autoincrement())
  id_factory       Int
  date             DateTime                  @db.Date
  shift            Worksheet_shift_enum
  outgoing_user_id Int
  incoming_user_id Int?
  notes            String                    @db.Text
  issues_reported  String?                   @db.Text
  status           ShiftHandover_status_enum @default(DRAFT)
  created_at       DateTime                  @default(now()) @db.Timestamp(6)
  submitted_at     DateTime?                 @db.Timestamp(6)
  acknowledged_at  DateTime?                 @db.Timestamp(6)
  Factory          Factory                   @relation(fields: [id_factory], references: [id])
  OutgoingUser     User                      @relation("HandoverOutgoing", fields: [outgoing_user_id], references: [id])
  IncomingUser     User?                     @relation("HandoverIncoming", fields: [incoming_user_id], references: [id])

  @@index([id_factory])
  @@index([date])
  @@index([shift])
}
